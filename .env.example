# ─────────────────────────────────────────────────────────────────────────────
# CRMNadya — Environment variables
# Скопировать в .env и заполнить значения
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# Frontend URL для CORS (обязателен в production)
CORS_ORIGIN=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crmnadya
DB_USER=crmnadya
DB_PASSWORD=changeme_in_production
DB_POOL_MAX=10

# ── JWT и сессии ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=8h

# bcrypt: 12 — production, 10 — dev для скорости
BCRYPT_ROUNDS=12

# ── Первый администратор (создаётся при миграции, если не существует) ─────────
ADMIN_EMAIL=admin@crmnadya.local
ADMIN_PASSWORD=changeme_strong_password

# ── AI провайдер (опционально, для AI-отчётов в Phase 2) ──────────────────────
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── Push notifications (опционально) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@crmnadya.local

# ── Загруженные файлы ─────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=20
